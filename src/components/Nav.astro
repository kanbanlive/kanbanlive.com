---
import Logo from './Logo.astro';
import { LOGIN_URL, TRIAL_URL } from '../lib/links';

const links = [
  { href: '/', label: 'Home' },
  { href: '/tour/', label: 'Tour' },
  { href: '/case-studies/', label: 'Case Studies' },
  { href: '/pricing/', label: 'Pricing' },
  { href: '/about/', label: 'About' },
  { href: '/contact/', label: 'Contact' },
];

// Normalise the current path (ignore trailing slash) so "/tour" and "/tour/" match.
const strip = (p: string) => (p !== '/' && p.endsWith('/') ? p.slice(0, -1) : p);
const current = strip(Astro.url.pathname);
const isActive = (href: string) => strip(href) === current;
---
<nav style="position:sticky; top:0; z-index:60; backdrop-filter:blur(14px); -webkit-backdrop-filter:blur(14px); background:var(--nav-bg); border-bottom:1px solid var(--border);">
  <div style="max-width:1200px; margin:0 auto; padding:16px 28px; display:flex; align-items:center; gap:22px; position:relative;">
    <a href="/" style="display:flex; align-items:center; gap:11px; text-decoration:none; flex:none;" aria-label="Kanban Live — home">
      <Logo width={30} height={27} />
      <span style="font-family:'Space Grotesk',sans-serif; font-weight:600; font-size:20px; letter-spacing:-.02em; color:var(--text);">Kanban Live</span>
    </a>

    <div class="kl-navlinks" data-open="false" style="display:flex; align-items:center; gap:20px; margin-left:2px; flex-wrap:wrap;">
      {links.map((link) => (
        isActive(link.href) ? (
          <a href={link.href} aria-current="page" style="text-decoration:none; color:var(--text); font-size:15px; font-weight:600; padding-bottom:2px; border-bottom:2px solid var(--accent-2);">{link.label}</a>
        ) : (
          <a href={link.href} style="text-decoration:none; color:var(--text-2); font-size:15px; font-weight:500;">{link.label}</a>
        )
      ))}
      <!-- Login lives in the top-bar on desktop; also surface it in the mobile dropdown -->
      <a href={LOGIN_URL} class="kl-navlogin" style="text-decoration:none; color:var(--text); font-size:15px; font-weight:600;">Login</a>
    </div>

    <div style="margin-left:auto; display:flex; align-items:center; gap:14px;">
      <button type="button" id="kl-burger" aria-label="Menu" aria-expanded="false" aria-controls="kl-navlinks" class="kl-burger" style="width:38px; height:38px; border-radius:10px; border:1px solid var(--border-strong); background:var(--surface); color:var(--text); cursor:pointer; align-items:center; justify-content:center; font-size:18px; line-height:1;">☰</button>
      <button type="button" id="kl-theme-toggle" aria-label="Toggle theme" style="width:38px; height:38px; border-radius:10px; border:none; background:transparent; color:var(--text-2); font-size:16px; cursor:pointer; display:flex; align-items:center; justify-content:center; line-height:1;" class="kl-lift">☾</button>
      <a href={LOGIN_URL} class="kl-loginlink" style="text-decoration:none; color:var(--text); font-size:15px; font-weight:600; padding:9px 4px;">Login</a>
      <a href={TRIAL_URL} class="kl-lift" style="text-decoration:none; background:var(--accent); color:var(--accent-ink); font-size:15px; font-weight:600; padding:10px 18px; border-radius:10px; box-shadow:0 6px 16px -6px var(--accent); white-space:nowrap;">Start free trial</a>
    </div>
  </div>
</nav>

<script>
  // Mobile nav disclosure — toggles data-open on the links panel (matched by
  // the ≤860px media query) and swaps the burger glyph.
  const burger = document.getElementById('kl-burger');
  const links = document.querySelector('.kl-navlinks');
  if (burger && links) {
    links.id = 'kl-navlinks';
    burger.addEventListener('click', () => {
      const open = links.getAttribute('data-open') === 'true';
      links.setAttribute('data-open', String(!open));
      burger.setAttribute('aria-expanded', String(!open));
      burger.textContent = open ? '☰' : '✕';
    });
    // Close the menu after following an in-page link.
    links.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).tagName === 'A') {
        links.setAttribute('data-open', 'false');
        burger.setAttribute('aria-expanded', 'false');
        burger.textContent = '☰';
      }
    });
  }
</script>
