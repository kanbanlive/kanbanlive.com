---
import Site from './Site.astro';
interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
}
const { title, description, eyebrow = 'Legal' } = Astro.props;
---
<Site title={title} description={description}>
  <header style="max-width:820px; margin:0 auto; padding:40px 32px 0;">
    <div style="font-size:13px; font-weight:700; letter-spacing:.08em; text-transform:uppercase; color:var(--accent);">{eyebrow}</div>
    <h1 style="font-family:'Space Grotesk',sans-serif; font-weight:600; font-size:clamp(30px,4.2vw,46px); line-height:1.08; letter-spacing:-.03em; margin:14px 0 0; color:var(--text); text-wrap:balance;">{title}</h1>
  </header>
  <section style="max-width:820px; margin:0 auto; padding:28px 32px 72px;">
    <div class="kl-prose">
      <slot />
    </div>
  </section>
</Site>
